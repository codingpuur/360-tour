# Storage provider: local | cloudinary | s3
# local  → files saved in public/uploads/ (no external service needed)
# cloudinary → requires CLOUDINARY_* vars below
STORAGE_PROVIDER=local

# MongoDB
MONGODB_URI=mongodb://localhost:27017/360-tour-platform

# NextAuth
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=http://localhost:3000

# Admin credentials (generate hash: PLAIN_PASSWORD=x npx tsx scripts/create-admin-hash.ts)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=

# Cloudinary (only needed when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
